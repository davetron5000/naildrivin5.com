digraph G {

  node[fontname=baskerville]

  ExistingSystem -> Developer
  ChangeRequest  -> Developer
  BestPractices  -> Developer
  Developer      -> ProposedChange
  ProposedChange -> Review
  Review         -> Developer[label="need revision"]
  Review         -> UpdatedSystem[label="looks good"]
  UpdatedSystem  -> SomeOutcome
  Note           -> SomeOutcome
  
  ExistingSystem [ shape=octagon       label="Any System"]
  ChangeRequest  [ shape=tab           label="Description of\lChange\l"]
  BestPractices  [ shape=cylinder      label="Tools and Techniques\lfor Quality Software\lConstruction\l"]
  Developer      [ shape=egg]
  ProposedChange [ shape=folder        label="Proposed Change"]
  Review         [ shape=diamond]
  UpdatedSystem  [ shape=doubleoctagon label="Updated System\nwith Change"]
  SomeOutcome    [ shape=rect          label="Some Observable\nOutcome"]
  Note           [ shape=note          label="This is all that\lreally matters\l" ]

  { rank=same; SomeOutcome; Note }
}

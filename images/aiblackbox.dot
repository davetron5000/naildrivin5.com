digraph G {

    node[fontname=baskerville]

    ExistingSystem -> BlackBox
    ChangeRequest  -> BlackBox
    BlackBox       -> UpdatedSystem
    UpdatedSystem  -> SomeOutcome
    Note           -> SomeOutcome

    ExistingSystem [ shape=octagon       label="Any System"]
    ChangeRequest  [ shape=tab           label="Description of\lChange\l"]
    BlackBox       [ shape=box3d         label="Black Box"]
    UpdatedSystem  [ shape=doubleoctagon label="Updated System\nwith Change"]
    SomeOutcome    [ shape=rect          label="Some Observable\nOutcome"]
    Note           [ shape=note          label="This is all that\lreally matters\l" ]

    { rank=same; SomeOutcome; Note }
}
